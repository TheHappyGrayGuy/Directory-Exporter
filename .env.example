# Copy this file to .env and fill in your values.
# .env is read automatically by docker compose.
# Never commit .env to git — it contains secrets.

# ── Identity ──────────────────────────────────────────────────────────────────
CONTAINER_NAME=directory-exporter

# ── Secret (for POST /-/reload) ───────────────────────────────────────────────
# Leave blank to auto-generate a random one each restart (logged on startup).
# Set a stable value so reloads work after container restarts.
RELOAD_SECRET=change-me-please

# ── Networking ────────────────────────────────────────────────────────────────
# Host port the metrics endpoint is bound to.
# Change if 9200 conflicts with another service on this host.
PORT=9200

# Name of the external Docker network created by your Prometheus/Grafana stack.
# Only needed when using docker-compose.monitoring.yml.
# Run: docker network ls | grep monitoring
MONITORING_NETWORK=monitoring_monitoring

# ── Config file ───────────────────────────────────────────────────────────────
# Path to your targets.yml on the HOST (mounted read-only into the container).
CONFIG_FILE_HOST=./targets.yml

# ── Data mounts ───────────────────────────────────────────────────────────────
# Host path for the first base directory declared in targets.yml.
# Add DATA_PATH_2, DATA_PATH_3 … for additional base paths and mirror them
# in the volumes: section of docker-compose.yml.
DATA_PATH_1=/home/javad/streams

# ── Scan tuning ───────────────────────────────────────────────────────────────
SCAN_INTERVAL=120s
SCAN_WORKERS=2
SCAN_TIMEOUT=90s
DISCOVERY_INTERVAL=6h

# Cap on lstat() calls per directory for timestamp computation.
# 0 = stat every file (accurate but slow on large dirs).
# 5000 = fast but timestamps only reflect the first 5k files.
MAX_STAT_FILES=5000
MAX_FILES_PER_DIR=0

# ── Resource limits ───────────────────────────────────────────────────────────
CPU_LIMIT=0.25
MEMORY_LIMIT=128M     # Docker container memory limit (Docker format: M/G)
GOMEMLIMIT=96MiB      # Go runtime soft cap (Go format: MiB/GiB — must be < MEMORY_LIMIT)
